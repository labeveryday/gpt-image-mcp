# GPT Image MCP Server Configuration
# Copy this file to .env and configure your settings

# Required: OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Advanced OpenAI Configuration
# OPENAI_BASE_URL=https://api.openai.com/v1   # Custom API endpoint
# OPENAI_ORGANIZATION=org-xxxxxxxxxxxxxxxxx    # Organization ID

# Optional: Model Selection
DEFAULT_MODEL=gpt-image-1                     # Primary model for image generation
IMAGE_MODEL=gpt-image-1                       # Direct image generation model
FALLBACK_MODEL=dall-e-3                       # Fallback model
ANALYSIS_MODEL=gpt-4o                         # Model for content analysis

# Optional: Performance Tuning
MAX_RETRIES=3                                 # Failed request retries
TIMEOUT_SECONDS=120                           # Request timeout
MAX_CONCURRENT_GENERATIONS=5                  # Batch processing limit
RATE_LIMIT_PER_MINUTE=30                      # API rate limiting

# Optional: Image Quality Settings
DEFAULT_QUALITY=auto                          # auto, high, medium, low
DEFAULT_SIZE=auto                             # auto or specific size
MAX_IMAGE_SIZE_MB=10.0                        # File size limit
ENABLE_COMPRESSION=true                       # Optimize file sizes

# Optional: YouTube Optimization
YOUTUBE_THUMBNAIL_SIZE=1792x1024              # Optimal thumbnail size

# Optional: Caching
ENABLE_CACHING=true                           # Response caching
CACHE_TTL_MINUTES=60                          # Cache duration

# Optional: Logging & Debugging
LOG_LEVEL=INFO                                # DEBUG, INFO, WARNING, ERROR
ENABLE_DETAILED_LOGGING=false                 # Request/response logging

# Optional: Security
ENABLE_CONTENT_FILTERING=true                 # Content safety filtering

# Optional: MCP Server Settings
SERVER_NAME=gpt-image-mcp                     # Server identifier
SERVER_VERSION=0.1.0                          # Version number
